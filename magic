#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<'EOF'
Usage: magic <host> [slot]
       magic <host> --list
       magic <host> --kill <slot>

Connect to a persistent session on a remote host. Sessions survive
disconnects and can be rejoined from any device.

  magic arc                  connect to default session on arc
  magic arc work             connect to a named session
  magic arc --list           show all live sessions on arc
  magic arc --kill work      terminate a session

Detach from a session: Ctrl+\  (session keeps running on the remote)

Slots are independent — run 'magic arc claude' in one terminal and
'magic arc logs' in another for two separate persistent sessions.
Multiple devices can join the same slot simultaneously.

Setup:
  ./install-local.sh         install magic on this machine
  ./install-remote.sh arc    install dtach on a remote host
EOF
    exit 0
fi

HOST="$1"
VERB="${2:-default}"

case "$VERB" in
  --list)
    echo "Sessions on $HOST:"
    ssh "$HOST" "ls /tmp/magic-*.sock 2>/dev/null | sed 's|/tmp/magic-||; s|\.sock||' || echo '  (none)'"
    ;;
  --kill)
    SLOT="${3:?--kill requires a slot name}"
    SOCK="/tmp/magic-${SLOT}.sock"
    ssh "$HOST" "bash -s" <<REMOTE
if [[ ! -S '$SOCK' ]]; then
    echo 'Not found: $SLOT'
    exit 1
fi
# kill the dtach master and everything in its process group
if command -v fuser &>/dev/null; then
    fuser -k '$SOCK' 2>/dev/null || true
elif command -v lsof &>/dev/null; then
    lsof -t '$SOCK' 2>/dev/null | xargs -r kill || true
fi
rm -f '$SOCK'
echo 'Killed: $SLOT'
REMOTE
    ;;
  *)
    SLOT="$VERB"
    SOCK="/tmp/magic-${SLOT}.sock"
    echo "→ $HOST / $SLOT"
    while true; do
        ssh -t "$HOST" "dtach -A '$SOCK' \$SHELL" && break
        echo "Reconnecting in 3s… (Ctrl+C to quit)"
        sleep 3
    done
    ;;
esac
